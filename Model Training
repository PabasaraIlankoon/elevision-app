def run_training(config, resume=False):
    """Run YOLO training. Returns (results, model) or (None, None)."""
    print(f'\n      Start: {datetime.now().strftime("%Y-%m-%d %H:%M:%S")}')
    print(f'      Resume mode: {resume}')
    try:
        model = YOLO(config['model'])
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

        results = model.train(
            data             = DATASET_YAML,
            epochs           = config['epochs'],
            imgsz            = config['imgsz'],
            batch            = config['batch_size'],
            device           = config['device'],
            optimizer        = config['optimizer'],
            lr0              = config['lr0'],
            lrf              = config['lrf'],
            momentum         = config['momentum'],
            weight_decay     = config['weight_decay'],
            warmup_epochs    = config['warmup_epochs'],
            warmup_momentum  = config['warmup_momentum'],
            cos_lr           = config['cos_lr'],
            patience         = config['patience'],
            hsv_h            = config['hsv_h'],
            hsv_s            = config['hsv_s'],
            hsv_v            = config['hsv_v'],
            degrees          = config['degrees'],
            translate        = config['translate'],
            scale            = config['scale'],
            shear            = config['shear'],
            perspective      = config['perspective'],
            flipud           = config['flipud'],
            fliplr           = config['fliplr'],
            mosaic           = config['mosaic'],
            mixup            = config['mixup'],
            copy_paste       = config['copy_paste'],
            close_mosaic     = config['close_mosaic'],
            amp              = config['amp'],
            half             = config['half'],
            save             = True,
            save_period      = config['save_period'],
            project          = dirs['runs'],
            name             = f"elephant_{datetime.now().strftime('%Y%m%d_%H%M%S')}",
            exist_ok         = True,
            verbose          = config['verbose'],
            resume           = resume,
        )

        print(f'\n      Training complete: {datetime.now().strftime("%Y-%m-%d %H:%M:%S")}')
        checkpoint_mgr.metadata['epochs_completed'] = config['epochs']
        checkpoint_mgr.metadata['training_count']  += 1
        lm = checkpoint_mgr.get_last_checkpoint()
        checkpoint_mgr.metadata['last_model']    = lm
        checkpoint_mgr.metadata['last_run_dir']  = os.path.dirname(os.path.dirname(lm)) if lm else None
        checkpoint_mgr.save()
        return results, model

    except AssertionError as e:
        if 'training' in str(e).lower() and 'finished' in str(e).lower():
            print('      Previous run already finished — starting fresh.')
            return run_training(config, resume=False)
        print(f'      AssertionError: {e}')
        return None, None

    except RuntimeError as e:
        if 'out of memory' in str(e).lower():
            print('      GPU OOM — suggestions:')
            print(f"        • batch {config['batch_size']} → 8")
            print(f"        • imgsz {config['imgsz']} → 512")
            print( '        • model yolov8s.pt')
            print( '      Re-run this cell to auto-resume.')
        else:
            print(f'      RuntimeError: {e}')
        return None, None

    except KeyboardInterrupt:
        print('      Training interrupted — re-run this cell to resume.')
        return None, None

    finally:
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()


