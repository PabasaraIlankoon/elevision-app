        return None, None
    latest_run  = os.path.join(runs_dir, runs[0])
    results_csv = os.path.join(latest_run, 'results.csv')
    if not os.path.exists(results_csv):
        return None, None
    df = pd.read_csv(results_csv)
    df.columns = df.columns.str.strip()         # strip whitespace from column names
    return df, latest_run


def detect_overfitting(df):
    """Return a human-readable overfitting diagnosis."""
    lines = []
    if 'train/box_loss' in df.columns and 'val/box_loss' in df.columns:
        gap = float(df['val/box_loss'].iloc[-1]) - float(df['train/box_loss'].iloc[-1])
        lines.append(f'  Box-loss gap (val - train): {gap:+.4f}')
        if gap > 0.10:
            lines.append('  >> OVERFIT LIKELY  — val loss much higher than train loss.')
            lines.append('     Try: +weight_decay, +mixup, +copy_paste, yolov8s.pt, fewer epochs.')
        elif gap > 0.05:
            lines.append('  >> MILD OVERFIT — monitor closely.')
        else:
            lines.append('  >> No strong overfit signal from loss gap.')
    return lines


def plot_training_curves(df, save_dir):
    fig = plt.figure(figsize=(22, 16))
    fig.suptitle('Elephant Detection — Training Analysis (50 Epochs)', fontsize=16, fontweight='bold', y=1.01)

    # Row 1: Losses
    for col_idx, (train_col, val_col, title, color_t, color_v) in enumerate([
        ('train/box_loss', 'val/box_loss', 'Box Loss',            'steelblue',   'tomato'),
        ('train/cls_loss', 'val/cls_loss', 'Classification Loss', 'seagreen',    'orange'),
        ('train/dfl_loss', 'val/dfl_loss', 'DFL Loss',            'mediumpurple','hotpink'),
    ], start=1):
        ax = plt.subplot(3, 3, col_idx)
        if train_col in df.columns and val_col in df.columns:
            ax.plot(df.index, df[train_col], color=color_t, linewidth=2, label='Train', alpha=0.85)
            ax.plot(df.index, df[val_col],   color=color_v, linewidth=2, label='Val',   alpha=0.85)
            ax.fill_between(df.index,
                            df[train_col], df[val_col],
                            alpha=0.10, color='grey', label='Gap (overfit indicator)')
        ax.set_title(title, fontsize=13, fontweight='bold')
        ax.set_xlabel('Epoch'); ax.set_ylabel('Loss')
        ax.legend(fontsize=9); ax.grid(True, alpha=0.3)

    # Row 2: Precision, Recall, F1
    ax4 = plt.subplot(3, 3, 4)
    if 'metrics/precision(B)' in df.columns:
        ax4.plot(df.index, df['metrics/precision(B)'], color='seagreen', linewidth=2.2)
        ax4.axhline(y=0.90, color='red',    linestyle='--', alpha=0.5, label='Target 0.90')
        ax4.axhline(y=0.95, color='orange', linestyle='--', alpha=0.5, label='Caution 0.95 (overfit?)')
    ax4.set_title('Precision', fontsize=13, fontweight='bold', color='seagreen')
    ax4.set_ylim([0, 1.05]); ax4.grid(True, alpha=0.3); ax4.legend(fontsize=9)

    ax5 = plt.subplot(3, 3, 5)
    if 'metrics/recall(B)' in df.columns:
        ax5.plot(df.index, df['metrics/recall(B)'], color='steelblue', linewidth=2.2)
        ax5.axhline(y=0.85, color='red', linestyle='--', alpha=0.5, label='Target 0.85')
    ax5.set_title('Recall', fontsize=13, fontweight='bold', color='steelblue')
    ax5.set_ylim([0, 1.05]); ax5.grid(True, alpha=0.3); ax5.legend(fontsize=9)

    ax6 = plt.subplot(3, 3, 6)
    if 'metrics/precision(B)' in df.columns and 'metrics/recall(B)' in df.columns:
        p  = df['metrics/precision(B)']
        r  = df['metrics/recall(B)']
        f1 = 2 * (p * r) / (p + r + 1e-7)
        ax6.plot(df.index, f1, color='mediumpurple', linewidth=2.2)
        ax6.axhline(y=0.87, color='red', linestyle='--', alpha=0.5, label='Target 0.87')
    ax6.set_title('F1 Score', fontsize=13, fontweight='bold', color='mediumpurple')
    ax6.set_ylim([0, 1.05]); ax6.grid(True, alpha=0.3); ax6.legend(fontsize=9)

    # Row 3: mAP, Fitness, Summary
    ax7 = plt.subplot(3, 3, 7)
    if 'metrics/mAP50(B)' in df.columns:
        ax7.plot(df.index, df['metrics/mAP50(B)'],    color='crimson',  linewidth=2.2, marker='d', markersize=3, label='mAP50')
    if 'metrics/mAP50-95(B)' in df.columns:
        ax7.plot(df.index, df['metrics/mAP50-95(B)'], color='darkorange', linewidth=2.2, marker='*', markersize=4, label='mAP50-95')
    ax7.set_title('mAP Metrics', fontsize=13, fontweight='bold', color='crimson')
    ax7.set_ylim([0, 1.05]); ax7.grid(True, alpha=0.3); ax7.legend(fontsize=9)

    ax8 = plt.subplot(3, 3, 8)
    if 'fitness' in df.columns:
        ax8.fill_between(df.index, df['fitness'], alpha=0.25, color='cyan')
        ax8.plot(df.index, df['fitness'], color='darkcyan', linewidth=2.8)
        best_ep  = int(df['fitness'].idxmax())
        best_fit = float(df['fitness'].max())
        ax8.scatter([best_ep], [best_fit], c='red', s=150, marker='*', zorder=5,
                    label=f'Best: {best_fit:.4f} @ ep {best_ep+1}')
    ax8.set_title('Overall Fitness', fontsize=13, fontweight='bold')
    ax8.grid(True, alpha=0.3); ax8.legend(fontsize=9)

    ax9 = plt.subplot(3, 3, 9)
    ax9.axis('off')
    summary  = '─── TRAINING SUMMARY ───\n'
    summary += f'Epochs: {len(df)}\n'
    if 'metrics/mAP50(B)' in df.columns:
        bme = int(df['metrics/mAP50(B)'].idxmax())
        summary += f'mAP50  best : {df["metrics/mAP50(B)"].max():.4f}  (ep {bme+1})\n'
        summary += f'mAP50  final: {df["metrics/mAP50(B)"].iloc[-1]:.4f}\n'
    if 'metrics/mAP50-95(B)' in df.columns:
        summary += f'mAP50-95   : {df["metrics/mAP50-95(B)"].iloc[-1]:.4f}\n'
    if 'metrics/precision(B)' in df.columns:
        summary += f'Precision  : {df["metrics/precision(B)"].iloc[-1]:.4f}\n'
    if 'metrics/recall(B)' in df.columns:
        summary += f'Recall     : {df["metrics/recall(B)"].iloc[-1]:.4f}\n'
    if 'metrics/precision(B)' in df.columns and 'metrics/recall(B)' in df.columns:
        p = float(df['metrics/precision(B)'].iloc[-1])
        r = float(df['metrics/recall(B)'].iloc[-1])
        summary += f'F1 (final) : {2*p*r/(p+r+1e-7):.4f}\n'
    if 'train/box_loss' in df.columns and 'val/box_loss' in df.columns:
        gap = float(df['val/box_loss'].iloc[-1]) - float(df['train/box_loss'].iloc[-1])
        summary += f'Loss gap   : {gap:+.4f}'

    ax9.text(0.07, 0.95, summary, va='top', fontsize=10.5, family='monospace',
             transform=ax9.transAxes,
             bbox=dict(boxstyle='round', facecolor='lightyellow', alpha=0.7))

    plt.tight_layout()
    save_path = os.path.join(save_dir, 'training_analysis_50ep.png')
    plt.savefig(save_path, dpi=150, bbox_inches='tight')
    plt.show()
    print(f'      Plots saved → {save_path}')
    return save_path


