class CheckpointManager:
    def __init__(self, checkpoint_dir):
        self.checkpoint_dir = checkpoint_dir
        self.metadata_file  = os.path.join(checkpoint_dir, 'training_metadata.json')
        self._load()

    def _load(self):
        if os.path.exists(self.metadata_file):
            with open(self.metadata_file, 'r', encoding='utf-8') as f:
                self.metadata = json.load(f)
        else:
            self.metadata = {
                'epochs_completed': 0,
                'best_fitness'    : 0.0,
                'training_count'  : 0,
                'last_model'      : None,
                'last_run_dir'    : None,
            }

    def save(self):
        with open(self.metadata_file, 'w', encoding='utf-8') as f:
            json.dump(self.metadata, f, indent=2)

    def get_last_checkpoint(self):
        """Return path to last.pt if a resumable checkpoint exists, else None."""
        runs_dir = dirs['runs']
        if not os.path.exists(runs_dir):
            return None
        runs = sorted(
            [d for d in os.listdir(runs_dir) if d.startswith('elephant_')],
            reverse=True
        )
        if not runs:
            return None
        last_pt = os.path.join(runs_dir, runs[0], 'weights', 'last.pt')
        return last_pt if os.path.exists(last_pt) else None

    def get_best_model(self):
        """Return path to best.pt (falls back to last.pt) or None."""
        runs_dir = dirs['runs']
        if not os.path.exists(runs_dir):
            return None
        runs = sorted(
            [d for d in os.listdir(runs_dir) if d.startswith('elephant_')],
            reverse=True
        )
        if not runs:
            return None
        latest = os.path.join(runs_dir, runs[0])
        best   = os.path.join(latest, 'weights', 'best.pt')
        last   = os.path.join(latest, 'weights', 'last.pt')
        if os.path.exists(best): return best
        if os.path.exists(last): return last
        return None

    def print_status(self):
        print(f"      Sessions completed : {self.metadata.get('training_count', 0)}")
        print(f"      Epochs tracked     : {self.metadata.get('epochs_completed', 0)}")
        print(f"      Best fitness       : {self.metadata.get('best_fitness', 0.0):.4f}")
        lm = self.get_last_checkpoint()
        if lm:
            print(f"      Last checkpoint    : {os.path.basename(os.path.dirname(lm))}")
        else:
            print('      Last checkpoint    : None (fresh start)')

